---
# Redirect external hostnames from HTTP to HTTPS. Internal (.lan) hosts are
# served plain HTTP and ACME challenge routes take precedence over this
# catch-all rule by path specificity.
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: https-redirect
  namespace: {{ gateway_namespace }}
spec:
  parentRefs:
    - name: {{ gateway_name }}
      sectionName: http
  hostnames:
{% for listener in gateway_https_listeners %}
    - {{ listener.hostname }}
{% endfor %}
{% for listener in gateway_local_https_listeners %}
    - {{ listener.hostname }}
{% endfor %}
  rules:
    - filters:
        - type: RequestRedirect
          requestRedirect:
            scheme: https
            statusCode: 301
