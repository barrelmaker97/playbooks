---
# Single wildcard certificate for internal LAN routes, issued by the internal
# self-signed CA. Let's Encrypt cannot issue certs for non-public domains so
# we mint our own. Lives in the gateway namespace alongside the public cert.
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: wildcard-lan
  namespace: {{ gateway_namespace }}
spec:
  secretName: wildcard-lan-tls
  privateKey:
    rotationPolicy: Always
  issuerRef:
    name: internal-ca
    kind: ClusterIssuer
  dnsNames:
    - "*.{{ cluster_domain }}"
