---
# Single wildcard Certificate covering the apex and all subdomains of the
# external domain. Issued via DNS-01 (Cloudflare) so it can be used for hosts
# that are not publicly routable on port 80. Every public HTTPS listener on
# the Gateway references the resulting secret.
apiVersion: cert-manager.io/v1
kind: Certificate
metadata:
  name: wildcard-public
  namespace: {{ gateway_namespace }}
spec:
  secretName: wildcard-public-tls
  privateKey:
    rotationPolicy: Always
  issuerRef:
    name: letsencrypt-prod
    kind: ClusterIssuer
  dnsNames:
    - "{{ external_domain }}"
    - "*.{{ external_domain }}"
